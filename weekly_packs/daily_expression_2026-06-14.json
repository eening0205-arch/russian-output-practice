{
  "title": "俄语输出练习",
  "theme": "俄语日常表达：安排、确认和请求",
  "week": "2026-06-14",
  "exercises": [
    {
      "id": "001",
      "prompt_zh": "我今天想早点出门。",
      "answer_ru": "Я сегодня хочу выйти пораньше.",
      "keywords": ["сегодня", "хочу", "выйти"],
      "explanation_zh": "хочу выйти 表示我想出去；пораньше 是早点，日常安排里很常用。",
      "difficulty": "easy"
    },
    {
      "id": "002",
      "prompt_zh": "你现在方便说话吗？",
      "answer_ru": "Тебе сейчас удобно говорить?",
      "keywords": ["сейчас", "удобно", "говорить"],
      "explanation_zh": "熟人之间可以用 тебе；如果要更礼貌，可以说 Вам сейчас удобно говорить?",
      "difficulty": "easy"
    },
    {
      "id": "003",
      "prompt_zh": "我可能会晚十分钟。",
      "answer_ru": "Я, возможно, опоздаю на десять минут.",
      "keywords": ["возможно", "опоздаю", "десять минут"],
      "explanation_zh": "опоздаю 表示我会迟到；на десять минут 表示迟到十分钟。",
      "difficulty": "medium"
    },
    {
      "id": "004",
      "prompt_zh": "我已经在路上了。",
      "answer_ru": "Я уже в дороге.",
      "keywords": ["уже", "дороге"],
      "explanation_zh": "в дороге 是在路上，短句很自然，适合回复别人催问。",
      "difficulty": "easy"
    },
    {
      "id": "005",
      "prompt_zh": "你到的时候给我写一下。",
      "answer_ru": "Напиши мне, когда будешь на месте.",
      "keywords": ["напиши", "мне", "место"],
      "explanation_zh": "на месте 表示到地方、到现场；напиши мне 是给我写一下。",
      "difficulty": "medium"
    },
    {
      "id": "006",
      "prompt_zh": "我在门口等你。",
      "answer_ru": "Я жду тебя у двери.",
      "keywords": ["жду", "тебя", "дверь"],
      "explanation_zh": "у двери 是在门旁边、门口；жду тебя 是我等你。",
      "difficulty": "easy"
    },
    {
      "id": "007",
      "prompt_zh": "可以再说一遍吗？",
      "answer_ru": "Можно повторить ещё раз?",
      "keywords": ["можно", "повторить", "ещё раз"],
      "explanation_zh": "можно 加不定式可以礼貌地提出请求；ещё раз 是再一次。",
      "difficulty": "easy"
    },
    {
      "id": "008",
      "prompt_zh": "我没听清楚。",
      "answer_ru": "Я не расслышала.",
      "keywords": ["не расслышала"],
      "explanation_zh": "女性说 расслышала；男性说 расслышал。意思是没听清，不是完全没听见。",
      "difficulty": "medium"
    },
    {
      "id": "009",
      "prompt_zh": "我差不多准备好了。",
      "answer_ru": "Я почти готова.",
      "keywords": ["почти", "готова"],
      "explanation_zh": "女性说 готова；男性说 готов。почти 表示差不多、几乎。",
      "difficulty": "easy"
    },
    {
      "id": "010",
      "prompt_zh": "给我一点时间。",
      "answer_ru": "Дай мне немного времени.",
      "keywords": ["мне", "немного", "время"],
      "explanation_zh": "немного времени 是一点时间；熟人之间用 дай，更礼貌可以说 дайте。",
      "difficulty": "easy"
    },
    {
      "id": "011",
      "prompt_zh": "这个问题我们之后再决定。",
      "answer_ru": "Этот вопрос мы решим позже.",
      "keywords": ["вопрос", "решим", "позже"],
      "explanation_zh": "решим 表示我们会决定、会解决；позже 是晚点、之后。",
      "difficulty": "medium"
    },
    {
      "id": "012",
      "prompt_zh": "我不确定，但可以试试。",
      "answer_ru": "Я не уверена, но можно попробовать.",
      "keywords": ["не уверена", "можно", "попробовать"],
      "explanation_zh": "女性说 уверена；男性说 уверен。можно попробовать 是可以试试。",
      "difficulty": "medium"
    },
    {
      "id": "013",
      "prompt_zh": "您说得对。",
      "answer_ru": "Вы правы.",
      "keywords": ["вы", "правы"],
      "explanation_zh": "Вы правы 是礼貌表达，表示您是对的、您说得对。",
      "difficulty": "easy"
    },
    {
      "id": "014",
      "prompt_zh": "我先看看，然后告诉你。",
      "answer_ru": "Я сначала посмотрю, потом скажу тебе.",
      "keywords": ["сначала", "посмотрю", "потом"],
      "explanation_zh": "сначала... потом... 表示先……然后……，适合描述处理顺序。",
      "difficulty": "medium"
    },
    {
      "id": "015",
      "prompt_zh": "今天不太合适，明天可以。",
      "answer_ru": "Сегодня не очень удобно, завтра можно.",
      "keywords": ["сегодня", "завтра", "можно"],
      "explanation_zh": "не очень удобно 是不太方便；завтра можно 是明天可以。",
      "difficulty": "easy"
    },
    {
      "id": "016",
      "prompt_zh": "我马上回来。",
      "answer_ru": "Я сейчас вернусь.",
      "keywords": ["сейчас", "вернусь"],
      "explanation_zh": "сейчас вернусь 是非常常见的口语，表示我马上回来。",
      "difficulty": "easy"
    },
    {
      "id": "017",
      "prompt_zh": "我忘了带钥匙。",
      "answer_ru": "Я забыла взять ключи.",
      "keywords": ["забыла", "взять", "ключи"],
      "explanation_zh": "女性说 забыла；男性说 забыл。взять ключи 是带钥匙。",
      "difficulty": "medium"
    },
    {
      "id": "018",
      "prompt_zh": "我可以坐这里吗？",
      "answer_ru": "Можно здесь сесть?",
      "keywords": ["можно", "здесь", "сесть"],
      "explanation_zh": "在公共场合询问能不能坐这里时，这句话很简洁自然。",
      "difficulty": "easy"
    },
    {
      "id": "019",
      "prompt_zh": "你能帮我一下吗？",
      "answer_ru": "Можешь мне помочь?",
      "keywords": ["можешь", "мне", "помочь"],
      "explanation_zh": "熟人之间用 можешь；更礼貌可以说 Вы можете мне помочь?",
      "difficulty": "easy"
    },
    {
      "id": "020",
      "prompt_zh": "没关系，下次吧。",
      "answer_ru": "Ничего страшного, в следующий раз.",
      "keywords": ["ничего страшного", "следующий раз"],
      "explanation_zh": "ничего страшного 表示没关系、不要紧；в следующий раз 是下次。",
      "difficulty": "easy"
    }
  ]
}
